import type { RouteRecordRaw } from 'vue-router'
import { createRouter, <%- options.routerMode === 'hash' ? 'createWebHashHistory' : 'createWebHistory' %> } from 'vue-router'

const routes: RouteRecordRaw[] = [
  {
    path: '/',
    redirect: '/dashboard/console',
  },
  {
    path: '/dashboard',
    name: 'Dashboard',
    component: () => import('@/views/index/index.vue'),
    redirect: '/dashboard/console',
    meta: { title: '仪表盘', icon: 'ri:pie-chart-line' },
    children: [
      {
        path: 'console',
        name: 'Console',
        component: () => import('@/views/dashboard/console/index.vue'),
        meta: {
          title: '工作台',
          icon: 'ri:home-smile-2-line',
          keepAlive: false,
          fixedTab: true,
        },
      },
      {
        path: 'analysis',
        name: 'Analysis',
        component: () => import('@/views/dashboard/analysis/index.vue'),
        meta: {
          title: '分析页',
          icon: 'ri:align-item-bottom-line',
          keepAlive: false,
        },
      },
    ],
  },
  {
    path: '/403',
    name: 'Forbidden',
    component: () => import('@/views/exception/403/index.vue'),
    meta: { title: '403' },
  },
  {
    path: '/404',
    name: 'NotFound',
    component: () => import('@/views/exception/404/index.vue'),
    meta: { title: '404' },
  },
  {
    path: '/500',
    name: 'ServerError',
    component: () => import('@/views/exception/500/index.vue'),
    meta: { title: '500' },
  },
  {
    path: '/:pathMatch(.*)*',
    redirect: '/404',
  },
]

const router = createRouter({
  history: <%- options.routerMode === 'hash' ? 'createWebHashHistory()' : "createWebHistory(import.meta.env.BASE_URL)" %>,
  routes,
})

export const HOME_PAGE_PATH = ''
export { router }
export default router

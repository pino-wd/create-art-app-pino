{
  "name": "<%= options.projectName %>",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "run-p type-check:app type-check:node",
    "type-check:app": "vue-tsc --noEmit -p tsconfig.app.json",
    "type-check:node": "tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"<% if (options.scaffold.docGovernance) { %>,
    "docs:lint": "node scripts/docs/lint-frontmatter.mjs && node scripts/docs/lint-naming.mjs && node scripts/docs/lint-no-private-path.mjs && node scripts/docs/lint-links.mjs"<% } %><% if (options.scaffold.commitChecks) { %>,
    "check:commit:fix": "lint-staged",
    "check:push": "<%= options.scaffold.docGovernance ? 'run-s lint type-check docs:lint' : 'run-s lint type-check' %>",
    "prepare": "husky"<% } %>
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@iconify/vue": "^4.3.0",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.7.9",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.7",
    "highlight.js": "^11.10.0",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "ohash": "^2.0.11",
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.2.0",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.0",
    "@types/nprogress": "^0.2.3",
    "@tailwindcss/vite": "^4.1.8",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^9.27.0",
    "eslint-plugin-format": "^1.0.1",
<% if (options.scaffold.docGovernance) { %>    "gray-matter": "^4.0.3",
<% } %><% if (options.scaffold.commitChecks) { %>    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
<% } %>
    "npm-run-all2": "^8.0.4",
    "sass": "^1.81.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.7.2",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-element-plus": "^0.8.0",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.3.5",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^2.2.10"
  }<% if (options.packageManager === 'pnpm') { %>,
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "esbuild"]
  }<% } %>
}
